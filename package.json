    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.77.0",
    "react-swipeable-list": "^1.10.0",
