  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-generate-if-available.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "biome format --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check:node": "node scripts/check-node-version.mjs",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:storybook": "vitest run --project storybook",
    "smoke:app": "node scripts/smoke-app.mjs",
    "smoke:visual": "node scripts/smoke-visual.mjs",
    "smoke:email-otp": "node scripts/smoke-email-otp.mjs",
    "smoke:webhook-receivers": "node scripts/smoke-webhook-receivers.mjs",
    "smoke:agent-ready": "node scripts/smoke-agent-ready.mjs",
    "smoke:docker": "node scripts/smoke-docker.mjs",
    "demo:seed": "node scripts/open-demo-seed.mjs",
    "press:screenshots": "node scripts/press-screenshots.mjs",
    "press:kit": "node scripts/build-press-kit.mjs",
    "release:check": "npm run check:node && npm run lint && npx tsc --noEmit && npm run test:unit && npm run test:storybook && npm run smoke:app && npm run smoke:visual && npm run smoke:email-otp && npm run build && npm run build-storybook && npm run smoke:docker",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "db:download-rds-ca": "node scripts/download-rds-ca.mjs",
    "db:generate": "node scripts/prisma-generate-if-available.mjs",
    "db:grant-runtime": "node scripts/grant-runtime-db-privileges.mjs",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/seed-bootstrap.mjs",
    "db:seed:admin": "node scripts/seed-admin.mjs",
    "postinstall": "node scripts/prisma-generate-if-available.mjs",
    "prepare": "husky || true"
  },
  "dependencies": {
