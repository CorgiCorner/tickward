{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tickward-scheduler",
  "main": "worker.ts",
  "compatibility_date": "2026-06-11",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
    "TICKWARD_BASE_URL": "https://yourdomain.com"
  },
  "triggers": {
    "crons": ["* * * * *"]
  }
}
